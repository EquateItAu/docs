{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ClassQuill",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#255a80",
    "light": "#88c1fb",
    "dark": "#1a3f5c"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.classquill.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://app.classquill.com"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Help Center",
        "pages": [
          {
            "group": "Getting Started",
            "pages": [
              "guides/overview",
              "guides/org-setup",
              "guides/invite-tutors",
              "guides/add-students",
              "guides/set-availability",
              "guides/how-parents-book"
            ]
          },
          {
            "group": "Scheduling",
            "pages": [
              "guides/scheduling/reschedule-cancel",
              "guides/scheduling/session-reminders"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "guides/billing/invoices",
              "guides/billing/online-payments",
              "guides/billing/transaction-history"
            ]
          },
          {
            "group": "Student Portal",
            "pages": [
              "guides/student-portal/what-parents-students-see",
              "guides/student-portal/progress-reports"
            ]
          },
          {
            "group": "AI Features",
            "pages": [
              "guides/ai/auto-grading",
              "guides/ai/practice-questions",
              "guides/ai/ai-study-assistant"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "pages": [
          {
            "group": "Getting Started",
            "pages": ["introduction", "authentication", "quickstart"]
          }
        ]
      }
    ]
  },
  "openapi": "/openapi.yaml",
  "api": {
    "baseUrl": "https://api.classquill.com",
    "auth": {
      "method": "key",
      "name": "Authorization",
      "inputPrefix": "Token token="
    }
  },
  "footer": {
    "socials": {
      "website": "https://classquill.com"
    }
  }
}
