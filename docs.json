{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ClassQuill API",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#255a80",
    "light": "#88c1fb",
    "dark": "#1a3f5c"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.classquill.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://app.classquill.com/org/settings"
    }
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": ["introduction", "authentication", "quickstart"]
      }
    ]
  },
  "openapi": "/openapi.yaml",
  "api": {
    "baseUrl": "https://api.classquill.com",
    "auth": {
      "method": "key",
      "name": "Authorization",
      "inputPrefix": "Token token="
    }
  },
  "footer": {
    "socials": {
      "website": "https://classquill.com"
    }
  }
}
